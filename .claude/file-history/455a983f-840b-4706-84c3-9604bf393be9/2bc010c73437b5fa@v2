<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Places — The Obsidian Assembly</title>
  <meta name="theme-color" content="#151415" />
  <meta name="color-scheme" content="dark" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@studio-freight/lenis/bundled/lenis.min.css" />

  <link rel="stylesheet" href="css/tokens.css" />
  <link rel="stylesheet" href="css/base.css" />
  <link rel="stylesheet" href="css/header.css" />
  <link rel="stylesheet" href="css/footer.css" />
  <link rel="stylesheet" href="css/inner.css" />
</head>
<body>
  <main class="page inner-page">

    <header role="banner">
      <div class="-w">
        <a href="/" class="-nl">
          <span class="-h5 the">The</span>
          <span class="-h5 obsidian">Obsidian</span>
          <span class="-h5 assembly">Assembly</span>
          <span class="-mm">/ places</span>
        </a>
        <span class="sep"></span>
        <a href="/places" class="button -m places"><span data-split>Places</span></a>
        <a href="/objects" class="button -m objects"><span data-split>Objects</span></a>
        <button type="button" class="button -m request" data-action="toggle-form">
          <span data-split>Request</span>
        </button>
        <div class="menu-wrap">
          <button type="button" class="button -m" data-action="toggle-menu">
            <span class="menu-icon"></span>
            <span class="text -mm -up">Menu</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Menu Overlay -->
    <div class="full-screen-menu" id="menu-overlay" style="--top-position: 0; display: none;">
      <span class="overlay"></span>
      <div class="oy">
        <div class="-w">
          <button type="button" class="button-close" data-action="toggle-menu"><span>Close</span></button>
          <nav>
            <div class="guy">
              <img src="images/guys/g-1.webp" alt="" loading="lazy" />
              <span class="-h5 -m-hp" data-split>Navigation</span>
            </div>
            <a href="/" class="-h0 -nl" data-split>Home</a>
            <a href="/places" class="-h0 -nl" data-split>Places</a>
            <a href="/objects" class="-h0 -nl" data-split>Objects</a>
            <a href="/about" class="-h0 -nl" data-split>About</a>
            <span class="-h0" data-split>Contacts</span>
            <a href="/people" class="-h0 -nl" data-split>People</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Form Overlay -->
    <div class="full-screen-form" id="form-overlay" style="--top-position: 0; display: none;">
      <span class="overlay" data-action="toggle-form"></span>
      <div class="oy">
        <div class="-w">
          <button type="button" class="button-close" data-action="toggle-form"><span>Close</span></button>
          <form id="admission-form-header">
            <div class="title">
              <span class="-h2" data-split>Request</span>
              <span class="-h2" data-split>Admission</span>
            </div>
            <div class="field name">
              <label class="-h6"><span>Full</span> <span>Name</span></label>
              <input type="text" name="name" placeholder="Name" required />
            </div>
            <div class="field email">
              <label class="-h6"><span>Email</span> <span>Address</span></label>
              <input type="email" name="email" placeholder="Email" required />
            </div>
            <div class="field country">
              <label class="-h6">Country</label>
              <input type="text" name="country" placeholder="Country" required />
            </div>
            <div class="field city">
              <label class="-h6">City</label>
              <input type="text" name="city" placeholder="City" required />
            </div>
            <div class="field tta">
              <label class="-h6"><span>Context for</span> <span>Admission /</span></label>
              <textarea name="context" placeholder="Tell us about yourself..." required minlength="10"></textarea>
            </div>
            <div class="agreement">
              <label class="-m">
                <input type="checkbox" name="agreement" required />
                <span>I understand that admission is reviewed selectively and may take time to process.</span>
              </label>
            </div>
            <div class="button-wrap">
              <button type="submit" class="button -big"><span>Submit Admission</span></button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Page Transition -->
    <div id="page-transition" style="display: none; --top-position: 0;">
      <div class="g">
        <span style="--order: 1; --order-back: 4;"></span>
        <span style="--order: 2; --order-back: 3;"></span>
        <span style="--order: 3; --order-back: 2;"></span>
        <span style="--order: 4; --order-back: 1;"></span>
      </div>
      <div class="t">
        <span>
          <span class="-h5 the" style="--order: 1;">The</span>
          <span class="-h5 obsidian" style="--order: 2;"> Obsidian</span>
          <span class="-h5 assembly" style="--order: 3;"> Assembly</span>
        </span>
      </div>
    </div>
    <div class="m-transition-underlay" id="mobile-transition" style="display: none; --top-position: 0;"></div>

    <!-- Success Modal -->
    <div class="submission-modal" id="success-modal" style="display: none;">
      <span class="overlay" data-action="close-modal"></span>
      <div class="content">
        <span class="-h3">Thank you</span>
        <p class="tt-1">Your request for admission has been received.</p>
        <button type="button" class="button -big" data-action="close-modal"><span>Close</span></button>
      </div>
    </div>

    <!-- Hero -->
    <section class="inner-hero" data-header-color="light">
      <div class="-w">
        <h1 class="-lrg" data-split>Places</h1>
        <p class="-h4">Distributed spaces across multiple locations.</p>
      </div>
    </section>

    <!-- Places Grid -->
    <section class="inner-grid" data-header-color="dark">
      <div class="-w">
        <div class="places-grid">
          <div class="place-card"><img src="images/offices/1.jpg" alt="Lower Hall" /><h3 class="-h4">Lower Hall</h3></div>
          <div class="place-card"><img src="images/offices/2.jpg" alt="Inner Chamber" /><h3 class="-h4">Inner Chamber</h3></div>
          <div class="place-card"><img src="images/offices/3.jpg" alt="The Passage" /><h3 class="-h4">The Passage</h3></div>
          <div class="place-card"><img src="images/offices/4.jpg" alt="Silent Room" /><h3 class="-h4">Silent Room</h3></div>
          <div class="place-card"><img src="images/offices/5.jpg" alt="The Threshold" /><h3 class="-h4">The Threshold</h3></div>
          <div class="place-card"><img src="images/offices/6.jpg" alt="The Vault" /><h3 class="-h4">The Vault</h3></div>
          <div class="place-card"><img src="images/offices/7.jpg" alt="Back Space" /><h3 class="-h4">Back Space</h3></div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer id="main-footer" data-header-color="dark">
      <div class="underlay"></div>
      <div class="-w block">
        <nav>
          <a href="/" class="-h5">Home</a>
          <a href="/places" class="-h5">Places</a>
          <a href="/objects" class="-h5">Objects</a>
          <a href="/about" class="-h5">About</a>
          <span class="-h5 contacts">Contacts</span>
          <a href="/people" class="-h5">People</a>
        </nav>
      </div>
      <div class="-w after">
        <a href="/" class="-nl">
          <span class="-h5 the">The</span>
          <span class="-h5 obsidian">Obsidian</span>
          <span class="-h5 assembly">Assembly</span>
        </a>
        <span class="-mm" style="color: rgba(255,255,255,0.3);">An independent organization coordinating distributed spaces, operations, and product development.</span>
        <span class="-mm" style="color: rgba(255,255,255,0.2); margin-top: var(--h2);">© 2025 The Obsidian Assembly</span>
      </div>
    </footer>

  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis/bundled/lenis.min.js"></script>
  <script src="js/split.js"></script>
  <script src="js/scroll.js"></script>
  <script src="js/header.js"></script>
  <script src="js/menu.js"></script>
  <script src="js/transition.js"></script>
  <script src="js/main.js"></script>
</body>
</html>
