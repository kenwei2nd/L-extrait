<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>The Obsidian Assembly</title>
  <meta name="theme-color" content="#151415" />
  <meta name="color-scheme" content="dark" />
  <meta name="description" content="The Obsidian Assembly is an independent organization coordinating distributed spaces, operations, and product development across multiple locations." />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;600&display=swap" rel="stylesheet" />

  <!-- Lenis Smooth Scroll -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@studio-freight/lenis/bundled/lenis.min.css" />

  <!-- Stylesheets -->
  <link rel="stylesheet" href="css/tokens.css" />
  <link rel="stylesheet" href="css/base.css" />
  <link rel="stylesheet" href="css/header.css" />
  <link rel="stylesheet" href="css/home.css" />
  <link rel="stylesheet" href="css/footer.css" />
</head>
<body>
  <main class="page home-page">

    <!-- ===== HEADER ===== -->
    <header role="banner">
      <div class="-w">
        <a href="/" class="-nl">
          <span class="-h5 the">The</span>
          <span class="-h5 obsidian">Obsidian</span>
          <span class="-h5 assembly">Assembly</span>
          <span class="-mm">/ index</span>
        </a>
        <span class="sep"></span>
        <a href="/places" class="button -m places">
          <span data-split>Places</span>
        </a>
        <a href="/objects" class="button -m objects">
          <span data-split>Objects</span>
        </a>
        <button type="button" class="button -m request" data-action="toggle-form">
          <span data-split>Request</span>
        </button>
        <div class="menu-wrap">
          <button type="button" class="button -m" data-action="toggle-menu">
            <span class="menu-icon"></span>
            <span class="text -mm -up">Menu</span>
          </button>
        </div>
      </div>
    </header>

    <!-- ===== MENU OVERLAY ===== -->
    <div class="full-screen-menu" id="menu-overlay" style="--top-position: 0; display: none;">
      <span class="overlay"></span>
      <div class="oy">
        <div class="-w">
          <button type="button" class="button-close" data-action="toggle-menu">
            <span>Close</span>
          </button>
          <div class="close"></div>
          <div class="underlay"><div></div></div>
          <nav>
            <div class="guy">
              <img src="images/guys/g-1.webp" alt="" loading="lazy" />
              <span class="-h5 -m-hp" data-split>Navigation</span>
            </div>
            <a href="/" class="-h0 -mid-h1 -m-h2 -nl back-home" style="--l-delay:1" data-split>Home</a>
            <a href="/places" class="-h0 -mid-h1 -m-h2 -nl places" style="--l-delay:1" data-split>Places</a>
            <a href="/objects" class="-h0 -mid-h1 -m-h2 -nl objects" style="--l-delay:2" data-split>Objects</a>
            <a href="/about" class="-h0 -mid-h1 -m-h2 -nl about" style="--l-delay:3" data-split>About</a>
            <span class="-h0 -mid-h1 -m-h2 -nl contacts" style="--l-delay:4" data-split>Contacts</span>
            <a href="/people" class="-h0 -mid-h1 -m-h2 -nl people" style="--l-delay:5" data-split>People</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- ===== FORM OVERLAY ===== -->
    <div class="full-screen-form" id="form-overlay" style="--top-position: 0; display: none;">
      <span class="overlay" data-action="toggle-form"></span>
      <div class="oy">
        <div class="-w">
          <button type="button" class="button-close" data-action="toggle-form">
            <span>Close</span>
          </button>
          <div class="close"></div>
          <div class="underlay"><div><figure></figure></div></div>
          <form id="admission-form-header">
            <div class="title">
              <span class="-h2" data-split>Request</span>
              <span class="-h2" data-split>Admission</span>
            </div>
            <div class="field name">
              <label class="-h6">
                <span>Full</span>
                <span>Name</span>
              </label>
              <input type="text" name="name" placeholder="Name" required />
            </div>
            <div class="field email">
              <label class="-h6">
                <span>Email</span>
                <span>Address</span>
              </label>
              <input type="email" name="email" placeholder="Email" required />
            </div>
            <div class="field country">
              <label class="-h6">Country</label>
              <input type="text" name="country" placeholder="Country" required />
            </div>
            <div class="field city">
              <label class="-h6">City</label>
              <input type="text" name="city" placeholder="City" required />
            </div>
            <div class="field tta">
              <label class="-h6">
                <span>Context for</span>
                <span>Admission /</span>
              </label>
              <textarea name="context" placeholder="Tell us about yourself..." required minlength="10"></textarea>
            </div>
            <div class="agreement">
              <label class="-m">
                <input type="checkbox" name="agreement" required />
                <span>I understand that admission is reviewed selectively and may take time to process.</span>
              </label>
            </div>
            <div class="button-wrap">
              <button type="submit" class="button -big">
                <span>Submit Admission</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- ===== PAGE TRANSITION OVERLAY ===== -->
    <div id="page-transition" style="display: none; --top-position: 0;">
      <div class="g">
        <span style="--order: 1; --order-back: 4;"></span>
        <span style="--order: 2; --order-back: 3;"></span>
        <span style="--order: 3; --order-back: 2;"></span>
        <span style="--order: 4; --order-back: 1;"></span>
      </div>
      <div class="t">
        <span>
          <span class="-h5 the" style="--order: 1;">The</span>
          <span class="-h5 obsidian" style="--order: 2;"> Obsidian</span>
          <span class="-h5 assembly" style="--order: 3;"> Assembly</span>
        </span>
      </div>
    </div>
    <div class="m-transition-underlay" id="mobile-transition" style="display: none; --top-position: 0;"></div>

    <!-- ===== SUCCESS MODAL ===== -->
    <div class="submission-modal" id="success-modal" style="display: none;">
      <span class="overlay" data-action="close-modal"></span>
      <div class="content">
        <span class="-h3">Thank you</span>
        <p class="tt-1">Your request for admission has been received.</p>
        <p class="tt-2">We will review your application and be in touch.</p>
        <button type="button" class="button -big" data-action="close-modal">
          <span>Close</span>
        </button>
      </div>
    </div>

    <!-- ===== SECTIONS ===== -->

    <!-- Welcome -->
    <section class="welcome-section" data-header-color="light">
      <div class="-w">
        <h1 class="-lrg" data-split>Nothing Shown First</h1>
        <svg class="welcome-path" viewBox="0 0 1000 600">
          <defs>
            <clipPath id="arch" clipPathUnits="objectBoundingBox">
              <path id="arch-path" d="M 0 1 L 0 0.75 Q 0.5 0 1 0.75 L 1 1 Z" />
            </clipPath>
          </defs>
        </svg>
        <div class="stone" data-spotlight-angle="0" data-spotlight-distance="0">
          <img src="images/stone-wall.webp" alt="" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Places Carousel -->
    <section class="places-section" data-header-color="light">
      <div class="-w relief-bg" id="relief-bg-container">
        <canvas id="relief-canvas"></canvas>
      </div>
      <div class="-w places-carousel" id="places-carousel">
        <h2 class="-h1" data-split>Explore</h2>
        <div class="carousel-items">
          <div class="carousel-item" data-index="0">
            <h3 class="-h4">Lower Hall</h3>
            <img src="images/offices/1.jpg" alt="Lower Hall" loading="lazy" />
          </div>
          <div class="carousel-item" data-index="1">
            <h3 class="-h4">Inner Chamber</h3>
            <img src="images/offices/2.jpg" alt="Inner Chamber" loading="lazy" />
          </div>
          <div class="carousel-item" data-index="2">
            <h3 class="-h4">The Passage</h3>
            <img src="images/offices/3.jpg" alt="The Passage" loading="lazy" />
          </div>
          <div class="carousel-item" data-index="3">
            <h3 class="-h4">Silent Room</h3>
            <img src="images/offices/4.jpg" alt="Silent Room" loading="lazy" />
          </div>
          <div class="carousel-item" data-index="4">
            <h3 class="-h4">The Threshold</h3>
            <img src="images/offices/5.jpg" alt="The Threshold" loading="lazy" />
          </div>
          <div class="carousel-item" data-index="5">
            <h3 class="-h4">The Vault</h3>
            <img src="images/offices/6.jpg" alt="The Vault" loading="lazy" />
          </div>
          <div class="carousel-item" data-index="6">
            <h3 class="-h4">Back Space</h3>
            <img src="images/offices/7.jpg" alt="Back Space" loading="lazy" />
          </div>
        </div>
        <button type="button" class="carousel-prev" aria-label="Previous">←</button>
        <button type="button" class="carousel-next" aria-label="Next">→</button>
        <div class="carousel-progress"></div>
      </div>
    </section>

    <!-- Places After (transition) -->
    <section class="places-after-section" data-header-color="dark">
      <div class="-w">
        <h2 class="-h1" data-split>Distributed Operations</h2>
        <p class="-p" data-split>Across multiple continents and time zones.</p>
      </div>
    </section>

    <!-- Objects Section -->
    <section class="objects-section" data-header-color="dark">
      <div class="-w" id="objects-root">
        <h2 class="-h1" data-split>Objects</h2>
        <div class="objects-wrapper">
          <div class="object" data-sequence-order="0">
            <h3 class="-h3">(V) The Fox Spirit</h3>
            <img src="images/offices/3.jpg" alt="" loading="lazy" />
          </div>
          <div class="object" data-sequence-order="1">
            <h3 class="-h3">(III) The Guardian</h3>
            <img src="images/offices/4.jpg" alt="" loading="lazy" />
          </div>
          <div class="object" data-sequence-order="2">
            <h3 class="-h3">(VI) The Elder</h3>
            <img src="images/offices/5.jpg" alt="" loading="lazy" />
          </div>
          <div class="object" data-sequence-order="3">
            <h3 class="-h3">(I) The Rabbit Keeper</h3>
            <img src="images/offices/6.jpg" alt="" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- Connection Section -->
    <section class="connection-section" data-header-color="light">
      <div class="-w">
        <h2 class="-h1" data-split>Connection</h2>
        <p class="-p" data-split>Building pathways between thought and action.</p>
        <div class="connection-figure">
          <svg viewBox="0 0 200 200">
            <circle cx="100" cy="100" r="90" fill="none" stroke="currentColor" stroke-width="2" />
          </svg>
        </div>
      </div>
    </section>

    <!-- Updates Section -->
    <section class="updates-section">
      <div class="-w">
        <h2 class="-h1" data-split>Updates</h2>
        <div class="updates-carousel" id="updates-carousel">
          <div class="update-item" data-index="0">
            <h3 class="-h4">Initiative One</h3>
            <p class="-p">Overview of current developments and ongoing projects.</p>
          </div>
          <div class="update-item" data-index="1">
            <h3 class="-h4">Initiative Two</h3>
            <p class="-p">Exploring new approaches to distributed coordination.</p>
          </div>
          <div class="update-item" data-index="2">
            <h3 class="-h4">Initiative Three</h3>
            <p class="-p">Research into organizational structures and frameworks.</p>
          </div>
          <div class="update-item" data-index="3">
            <h3 class="-h4">Initiative Four</h3>
            <p class="-p">Development of collaborative tools and methodologies.</p>
          </div>
          <div class="update-item" data-index="4">
            <h3 class="-h4">Initiative Five</h3>
            <p class="-p">Building community and fostering long-term engagement.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- People Section -->
    <section class="people-section" data-header-color="light">
      <div class="-w">
        <h2 class="-h1" data-split>People</h2>
        <p class="-p" data-split>Individuals committed to expanding possibility.</p>
      </div>
    </section>

    <!-- Admission Section -->
    <section class="admission-section" data-header-color="dark">
      <div class="-w">
        <h2 class="-h1" data-split>Admission</h2>
        <form id="admission-form" class="admission-form">
          <div class="form-group">
            <label class="-h6" for="adm-name">
              <span>Full</span>
              <span>Name</span>
            </label>
            <input type="text" id="adm-name" name="name" placeholder="Name" required />
          </div>
          <div class="form-group">
            <label class="-h6" for="adm-email">
              <span>Email</span>
              <span>Address</span>
            </label>
            <input type="email" id="adm-email" name="email" placeholder="Email" required />
          </div>
          <div class="form-group">
            <label class="-h6" for="adm-country">Country</label>
            <input type="text" id="adm-country" name="country" placeholder="Country" required />
          </div>
          <div class="form-group">
            <label class="-h6" for="adm-city">City</label>
            <input type="text" id="adm-city" name="city" placeholder="City" required />
          </div>
          <div class="form-group">
            <label class="-h6" for="adm-context">
              <span>Context for</span>
              <span>Admission /</span>
            </label>
            <textarea id="adm-context" name="context" placeholder="Tell us about yourself..." required minlength="10"></textarea>
          </div>
          <div class="form-group form-agreement">
            <label class="-m">
              <input type="checkbox" name="agreement" required />
              <span>I understand that admission is reviewed selectively and may take time to process.</span>
            </label>
          </div>
          <button type="submit" class="button -big">
            <span>Submit Admission</span>
          </button>
        </form>
      </div>
    </section>

    <!-- Footer -->
    <footer id="main-footer" data-header-color="dark">
      <div class="underlay"></div>

      <!-- White card block with star-mask decorative edges -->
      <div class="-w block">
        <nav>
          <a href="/" class="-h5 back-home" data-split>Home</a>
          <a href="/places" class="-h5 places" data-split>Places</a>
          <a href="/objects" class="-h5 objects" data-split>Objects</a>
          <a href="/about" class="-h5 about" data-split>About</a>
          <span class="-h5 contacts" data-split>Contacts</span>
          <a href="/people" class="-h5 people" data-split>People</a>
        </nav>
      </div>

      <!-- Credits / after row -->
      <div class="-w after">
        <a href="/" class="-nl">
          <span class="-h5 the">The</span>
          <span class="-h5 obsidian">Obsidian</span>
          <span class="-h5 assembly">Assembly</span>
        </a>
        <span class="-mm" style="color: rgba(255,255,255,0.3);">
          An independent organization coordinating distributed spaces, operations, and product development.
        </span>
        <span class="-mm" style="color: rgba(255,255,255,0.2); margin-top: var(--h2);">
          © 2025 The Obsidian Assembly
        </span>
      </div>

      <!-- Decorative stone sphere (parallax) -->
      <div class="stone-3">
        <img src="images/stone-wall.webp" alt="" />
      </div>
    </footer>

  </main>

  <!-- GSAP Libraries (CDN) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis/bundled/lenis.min.js"></script>

  <!-- Application Scripts -->
  <script src="js/split.js"></script>
  <script src="js/scroll.js"></script>
  <script src="js/header.js"></script>
  <script src="js/menu.js"></script>
  <script src="js/places.js"></script>
  <script src="js/objects.js"></script>
  <script src="js/updates.js"></script>
  <script src="js/admission.js"></script>
  <script src="js/sections.js"></script>
  <script src="js/transition.js"></script>
  <script src="js/main.js"></script>
</body>
</html>
