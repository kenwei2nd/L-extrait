<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{BRAND_NAME}} - Video to Web</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <!-- Loader -->
  <div id="loader">
    <div class="loader-content">
      <div class="loader-brand">{{BRAND_NAME}}</div>
      <div class="loader-bar">
        <div id="loader-progress" class="loader-progress"></div>
      </div>
      <div id="loader-percent" class="loader-percent">0%</div>
    </div>
  </div>

  <!-- Site Header -->
  <header class="site-header">
    <nav class="site-nav">
      <div class="nav-logo">{{BRAND_NAME}}</div>
      <ul class="nav-links">
        <li><a href="#features">Features</a></li>
        <li><a href="#stats">Stats</a></li>
        <li><a href="#cta">Get Started</a></li>
      </ul>
    </nav>
  </header>

  <!-- Hero Section -->
  <section class="hero-standalone">
    <div class="hero-content">
      <span class="section-label">001 / Intro</span>
      <h1 class="hero-heading">
        <span>Welcome</span>
        <span>to</span>
        <span>{{BRAND_NAME}}</span>
      </h1>
      <p class="hero-tagline">Experience scroll-driven animation like never before</p>
      <div class="scroll-indicator">
        <span>Scroll to explore</span>
        <div class="arrow">↓</div>
      </div>
    </div>
  </section>

  <!-- Canvas Container (Fixed) -->
  <div class="canvas-wrap">
    <canvas id="canvas"></canvas>
  </div>

  <!-- Dark Overlay -->
  <div id="dark-overlay"></div>

  <!-- Marquee -->
  <div class="marquee-wrap" data-scroll-speed="-25">
    <div class="marquee-text">{{BRAND_NAME}} • PREMIUM • INTERACTIVE • SCROLL-DRIVEN •</div>
  </div>

  <!-- Scroll Container -->
  <div id="scroll-container">
    <!-- Section 1: Feature -->
    <section class="scroll-section section-content align-left"
             data-enter="22" data-leave="38" data-animation="fade-up">
      <div class="section-inner">
        <span class="section-label">002 / Feature One</span>
        <h2 class="section-heading">Feature Headline</h2>
        <p class="section-body">Description of the feature and its benefits. This text appears on the left side while the video canvas animates in the center.</p>
        <a href="#" class="section-link">Learn more →</a>
      </div>
    </section>

    <!-- Section 2: Feature -->
    <section class="scroll-section section-content align-right"
             data-enter="38" data-leave="54" data-animation="slide-left">
      <div class="section-inner">
        <span class="section-label">003 / Feature Two</span>
        <h2 class="section-heading">Another Great Feature</h2>
        <p class="section-body">Another description highlighting different aspects of your product. Text alternates side for visual interest.</p>
        <a href="#" class="section-link">Discover →</a>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="scroll-section section-stats"
             data-enter="54" data-leave="72" data-animation="stagger-up">
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-number" data-value="98" data-decimals="0">0</span>
          <span class="stat-suffix">%</span>
          <span class="stat-label">Client Satisfaction</span>
        </div>
        <div class="stat">
          <span class="stat-number" data-value="500" data-decimals="0">0</span>
          <span class="stat-suffix">+</span>
          <span class="stat-label">Projects Completed</span>
        </div>
        <div class="stat">
          <span class="stat-number" data-value="24" data-decimals="0">0</span>
          <span class="stat-suffix">hrs</span>
          <span class="stat-label">Support Response</span>
        </div>
      </div>
    </section>

    <!-- Feature Section 3 -->
    <section class="scroll-section section-content align-left"
             data-enter="72" data-leave="88" data-animation="slide-right">
      <div class="section-inner">
        <span class="section-label">004 / Feature Three</span>
        <h2 class="section-heading">Innovation at Scale</h2>
        <p class="section-body">Our platform scales with your needs. Whether you're a startup or enterprise, we've got you covered.</p>
        <a href="#" class="section-link">See plans →</a>
      </div>
    </section>

    <!-- CTA Section (Persists) -->
    <section class="scroll-section section-cta"
             data-enter="88" data-leave="100" data-animation="scale-up" data-persist="true">
      <div class="section-inner">
        <span class="section-label">005 / Call to Action</span>
        <h2 class="section-heading">Ready to Get Started?</h2>
        <p class="section-body">Join thousands of satisfied customers building beautiful scroll-driven experiences.</p>
        <button class="cta-button">Start Your Project</button>
      </div>
    </section>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/lenis@1/dist/lenis.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
  <script src="js/app.js"></script>
</body>
</html>
