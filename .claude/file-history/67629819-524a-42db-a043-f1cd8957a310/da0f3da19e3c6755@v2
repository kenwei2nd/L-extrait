/* ============================================================
   Globe Section — dark ink, continuous from About
   Interactive globe with flight arcs
   Bottom fades ink → paper for Showcase transition
   ============================================================ */

.globe {
  position: relative;
  background: var(--ink);
  color: var(--paper);
  font-family: var(--font-display);
  padding-bottom: 0;
  overflow: hidden;
}

.inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: clamp(24px, 4vw, 64px) clamp(24px, 6vw, 80px) clamp(40px, 6vw, 80px);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(32px, 5vw, 64px);
  align-items: center;
}

/* ---------- Text block ---------- */
.head {
  padding-right: clamp(16px, 3vw, 40px);
}

.eyebrow {
  font-size: clamp(10px, 0.8vw, 12px);
  font-weight: 500;
  letter-spacing: 0.42em;
  text-indent: 0.42em;
  color: rgba(255, 255, 255, 0.3);
  margin-bottom: clamp(16px, 2.5vh, 24px);
}

.headline {
  font-size: clamp(40px, 6vw, 88px);
  font-weight: 600;
  line-height: 0.97;
  letter-spacing: -0.04em;
  color: var(--paper);
  margin-bottom: clamp(20px, 3vh, 32px);
  display: flex;
  flex-direction: column;
  gap: 0.04em;
}

.lineWrap {
  display: block;
  overflow: hidden;
}

.lineInner {
  display: block;
  transform: translateY(110%);
}

.sub {
  font-size: clamp(14px, 1.1vw, 17px);
  font-weight: 400;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.4);
}

/* ---------- Globe ---------- */
.globeWrap {
  display: flex;
  justify-content: center;
  align-items: center;
  will-change: transform, opacity;
}

.globePlaceholder {
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, rgba(30,58,138,0.3), rgba(10,13,18,0.8));
  border: 1px solid rgba(255, 255, 255, 0.06);
}

/* ---------- ink → paper transition ---------- */
.bottomFade {
  height: 18vh;
  background: linear-gradient(to bottom, transparent, var(--paper));
  pointer-events: none;
}

/* ---------- Responsive ---------- */
@media (max-width: 900px) {
  .inner {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .head {
    padding-right: 0;
  }

  .globeWrap {
    max-width: 440px;
    margin: 0 auto;
  }
}
