/**
 * Scroll System Setup
 * - Lenis smooth scroll initialization
 * - GSAP ScrollTrigger proxying
 * - Viewport unit calculation (--vh, --vw)
 * - Initial load animation sequence (.-loaded, .-ready classes)
 */

let lenis = null;

function initLenis() {
  // Initialize Lenis smooth scroll
  lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    direction: 'vertical',
    gestureDirection: 'vertical',
    smooth: true,
  });

  // Proxy GSAP to use Lenis for scroll
  lenis.on('scroll', ({ velocity, direction, progress }) => {
    ScrollTrigger.update();
  });

  // Update GSAP on each Lenis frame
  const raf = (time) => {
    lenis.raf(time);
    requestAnimationFrame(raf);
  };
  requestAnimationFrame(raf);

  // Sync GSAP's internal scroll
  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });
}

function updateViewportUnits() {
  const vh = window.innerHeight * 0.01;
  const vw = window.innerWidth * 0.01;
  document.documentElement.style.setProperty('--vh', `${vh}px`);
  document.documentElement.style.setProperty('--vw', `${vw}px`);
}

function initScrollSystem() {
  // Initialize Lenis
  initLenis();

  // Set initial viewport units
  updateViewportUnits();

  // Update on resize
  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(updateViewportUnits, 200);
  });

  // Set up GSAP ScrollTrigger
  ScrollTrigger.scrollerProxy(document.documentElement, {
    scrollTop(value) {
      if (arguments.length) {
        lenis.scrollTo(value, { immediate: true });
      }
      return lenis.actualScroll;
    },
    getBoundingClientRect() {
      return {
        top: 0,
        left: 0,
        width: window.innerWidth,
        height: window.innerHeight,
      };
    },
    pinType: 'transform',
  });

  // Initial load sequence
  const html = document.documentElement;

  // Add .-loaded class after a small delay (CSS transitions unlock)
  setTimeout(() => {
    html.classList.add('-loaded');
  }, 100);

  // Add .-ready class after content is laid out
  setTimeout(() => {
    html.classList.add('-ready');
  }, 1300);
}

// Start on DOM ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initScrollSystem);
} else {
  initScrollSystem();
}

