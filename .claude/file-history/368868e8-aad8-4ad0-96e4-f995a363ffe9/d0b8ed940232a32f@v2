<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>404 — The Obsidian Assembly</title>
  <meta name="theme-color" content="#151415" />
  <meta name="color-scheme" content="dark" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;600&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="css/tokens.css" />
  <link rel="stylesheet" href="css/base.css" />
  <link rel="stylesheet" href="css/header.css" />
  <link rel="stylesheet" href="css/inner.css" />
  <style>
    .not-found {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: var(--h2);
      padding: var(--h1);
    }
    .not-found .-lrg {
      color: var(--c-yellow);
      opacity: 0.3;
    }
  </style>
</head>
<body>
  <main class="page inner-page">

    <header role="banner">
      <div class="-w">
        <a href="/" class="-nl">
          <span class="-h5 the">The</span>
          <span class="-h5 obsidian">Obsidian</span>
          <span class="-h5 assembly">Assembly</span>
        </a>
        <div class="menu-wrap" style="--left: 11;">
          <button type="button" class="button -m" onclick="window.history.back()">
            <span class="text -mm -up">Back</span>
          </button>
        </div>
      </div>
    </header>

    <section class="not-found" data-header-color="light">
      <span class="-lrg">404</span>
      <h1 class="-h1">Page not found</h1>
      <p class="-p" style="color: rgba(255,255,255,0.5); max-width: 400px;">This place does not exist within the Assembly's known coordinates.</p>
      <a href="/" class="button -big"><span>Return Home</span></a>
    </section>

  </main>

  <script src="js/scroll.js" defer></script>
</body>
</html>
